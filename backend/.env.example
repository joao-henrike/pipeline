# =============================================================================
# .ENV.EXAMPLE — Copie para .env e preencha
# =============================================================================

# Qual cloud roda este backend (AWS ou AZURE)
CLOUD_PROVIDER=AWS

# AWS
AWS_REGION=us-east-1
AWS_EC2_INSTANCE_ID=i-0xxxxxxxxxx
AWS_EC2_PRIVATE_IP=10.0.1.x
AWS_VPN_CONNECTION_ID=vpn-xxxxxxxxxx
AWS_VGW_ID=vgw-xxxxxxxxxx

# Azure
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-multicloud-SeuNome
AZURE_VM_NAME=vm-azure-SeuNome
AZURE_VM_PRIVATE_IP=10.1.1.x
AZURE_VPN_CONNECTION_NAME=conn-aws-t1-SeuNome

# Geral
STUDENT_NAME=SeuNome
OTHER_CLOUD_IP=10.x.x.x   # IP privado da VM na outra cloud
